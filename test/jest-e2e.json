{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": ".",
  "testEnvironment": "node",
  "testRegex": ".e2e-spec.ts$",
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "moduleNameMapper": {
    "^@root/(.*)$": "<rootDir>/../src/$1",
    "^@test/(.*)$": "<rootDir>/../test/$1",
    "^@resources/(.*)$": "<rootDir>/../resources/$1"
  },
  "setupFilesAfterEnv": ["<rootDir>/setup.e2e.ts"],
  "testTimeout": 30000,
  "maxWorkers": 1,
  "forceExit": true,
  "detectOpenHandles": true
}
